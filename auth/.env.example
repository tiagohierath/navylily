# Copy to auth/.env and fill in. The server auto-loads auth/.env on start.

# --- Server ---
PORT=8090
BIND_ADDR=127.0.0.1                       # interface to bind; 127.0.0.1 = local only (cloudflared reaches it). Use 0.0.0.0 to expose on the LAN.
SITE_URL=http://localhost:8090          # public URL of the auth server (no trailing slash)
COOKIE_SECURE=false                      # set true once you serve over HTTPS
SESSION_TTL_DAYS=30                       # how long a login session lasts (cookie + auth_sessions row)

# --- Self-hosted Supabase ---
# Base URL of your Supabase API gateway (Kong). NOT the Studio URL.
SUPABASE_URL=http://localhost:8000
# Find these in your self-hosted Supabase .env (ANON_KEY / SERVICE_ROLE_KEY)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Login is email + password (handled by Supabase Auth / GoTrue). On the Supabase
# side make sure email signups + passwords are enabled and email confirmations
# are ON, e.g. GOTRUE_EXTERNAL_EMAIL_ENABLED=true, GOTRUE_MAILER_AUTOCONFIRM=false.
# Confirmation and password-reset emails are sent by GoTrue's SMTP — point that
# at your Resend SMTP (same mailer the post-purchase login link already uses).
# Run the auth_sessions migration in supabase/migrations/ once (server-side sessions).

# --- Cloudflare Analytics (only used by stats.sh terminal dashboard) ---
# Optional. Powers the "Visitors" line in auth/stats.sh. Leave empty to show
# Users + Paid only (Visitors becomes n/a). Create a token with permission
# Zone -> Analytics : Read scoped to your zone; CF_ZONE_TAG is the Zone ID from
# the domain's Overview page (right sidebar), not the account id.
CF_API_TOKEN=
CF_ZONE_TAG=

# --- AbacatePay (PIX, Checkout Transparente) ---
# API key from the AbacatePay dashboard (Integrar -> API Keys). Used as Bearer
# to create PIX charges. v1 and v2 keys are NOT interchangeable; use a v2 key.
ABACATE_PAY_API_KEY=your-abacatepay-api-key
# Shared secret you set on the webhook; AbacatePay appends it as ?webhookSecret=.
ABACATE_WEBHOOK_SECRET=your-webhook-secret
# API base. Override only for testing; default targets v2.
ABACATE_API_URL=https://api.abacatepay.com/v2
# Charge amount in cents (197 BRL = 19700).
PRICE_CENTS=19700
# Credit card is only available through AbacatePay's hosted checkout, which bills
# a pre-created product. Create one once (POST /v2/products/create) and paste its
# id here. Leave empty to disable the card button (PIX still works).
ABACATE_PRODUCT_ID=
# Max card installments offered on the hosted checkout (1-12). Min R$10/installment.
CARD_MAX_INSTALLMENTS=12

# --- Resend (only used by gift.sh --notify to welcome legacy members) ---
# API key from resend.com (starts with re_). Leave empty to skip e-mailing.
RESEND_API_KEY=
# Verified sender on your Resend domain. Plain address or "Name <addr>".
RESEND_FROM=Navy Lily <noreply@yourdomain.com>

# --- Content ---
# Free lessons, served openly at / (this server is the single front door).
PUBLIC_DIR=../public
# Paid lessons, served ONLY through the /protected/ gate. Must live OUTSIDE
# PUBLIC_DIR so no static path can ever reach them.
PROTECTED_DIR=../protected
